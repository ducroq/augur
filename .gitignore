# ML model artifacts
ml/models/*.joblib
ml/models/*.tmp
!ml/models/.gitkeep
# river_model.pkl and state.json are committed daily by sadalsuud
!ml/models/river_model.pkl
!ml/models/state.json
# A/B experiment subdirs — committed on the experiment's feature branch only;
# local copies on main after a checkout-back are leftovers.
ml/models/river_baseline/
ml/models/river_p1/

# Experiment subdirectories: pickles/state are noisy, keep only backtest reports
ml/models/river_baseline/*
ml/models/river_p1/*
!ml/models/river_baseline/backtest_report.json
!ml/models/river_p1/backtest_report.json

# EXP-009 shadow: pickle is regenerated nightly from the rolling training
# window; only state/forecast/eval-log carry across runs and need committing.
ml/models/shadow/shadow_model.pkl
ml/models/shadow/shadow_model.pkl.hmac

# ML training data (derived, rebuild with consolidate.py)
ml/data/*.parquet

# ML forecast archive (daily copies on sadalsuud, for backtesting)
ml/forecasts/
